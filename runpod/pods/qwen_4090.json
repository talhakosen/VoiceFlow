{
  "name": "voiceflow-qwen-training",
  "imageName": "runpod/pytorch:2.2.0-py3.10-cuda12.1.1-devel-ubuntu22.04",
  "gpuTypeId": "NVIDIA GeForce RTX 4090",
  "gpuCount": 1,
  "cloudType": "SECURE",
  "containerDiskInGb": 120,
  "volumeInGb": 20,
  "volumeMountPath": "/workspace",
  "ports": "22/tcp,8888/http",
  "env": {
    "PUBLIC_KEY": "__YOUR_SSH_PUBLIC_KEY__",
    "HF_TOKEN": "__FROM_ENV__"
  },
  "_notes": [
    "Container disk 120GB: unsloth + model (4bit ~5GB) + dataset upload alanı",
    "Volume 20GB /workspace: adapter çıktısı (HF PEFT format, ~40MB) + train.log",
    "RTX 4090 24GB: Qwen 7B 4bit ~5GB, batch=8 rahat",
    "Eğitim sonrası /workspace/adapters/ Mac'e SCP ile çek → convert_adapter.py",
    "unsloth kurulum ~15 dakika (derleme gerektiriyor)"
  ],
  "_setup": "runpod/setup/qwen.sh",
  "_train_script": "ml/qwen/scripts/train_runpod.py",
  "_dataset_upload": "ml/qwen/datasets/train.jsonl + valid.jsonl → /workspace/",
  "_output": "/workspace/adapters/"
}
