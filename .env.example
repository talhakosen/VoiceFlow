# Copy this file to .env and fill in your values

# Trello (optional — used by /commit skill for board sync)
TRELLO_API_KEY=your_trello_api_key
TRELLO_ACCESS_TOKEN=your_trello_access_token
TRELLO_BOARD_ID=your_board_id

# Backend (server mode only)
BACKEND_MODE=local                         # local | server
JWT_SECRET=change-this-to-a-strong-secret  # required in server mode

# DB Encryption (ISO 27001 R-001) — empty = plaintext (local dev)
# Generate: openssl rand -hex 32
DB_ENCRYPTION_KEY=
JWT_ACCESS_TTL_MINUTES=60
API_KEYS=key1,key2                         # optional X-Api-Key fallback

# Models (server mode)
WHISPER_MODEL=large-v3
LLM_MODEL=qwen2.5:7b
LLM_ENDPOINT=http://ollama:11434

# HuggingFace (speeds up model downloads)
HF_TOKEN=your_hf_token
